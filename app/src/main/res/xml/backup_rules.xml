<?xml version="1.0" encoding="utf-8"?>
<!--
  ADR-0034 #12 — cloud (full) backup exclusions, corrected for the
  post-ADR-0024 storage layout. The old rule excluded a stale
  sharedpref `unraid_keys.xml` that no longer exists.

  Real storage (verified in ApiKeyStore.kt / SettingsStore.kt):
    datastore/unraid_prefs.preferences_pb  — server names + URLs (plaintext topology)
    datastore/unraid_keys.preferences_pb   — Tink AEAD ciphertext of API keys
    sharedpref/unraid_apikey_keyset_prefs.xml — Tink keyset (Keystore-wrapped)

  Exclude all three from cloud backup so neither the LAN topology, the
  ciphertext, nor the keyset leaves the device. The whole `datastore`
  directory is also excluded as a fail-safe (ADR-0034) in case a
  DataStore file name changes.
-->
<full-backup-content>
    <exclude domain="file" path="datastore" />
    <exclude domain="file" path="datastore/unraid_prefs.preferences_pb" />
    <exclude domain="file" path="datastore/unraid_keys.preferences_pb" />
    <exclude domain="sharedpref" path="unraid_apikey_keyset_prefs.xml" />
</full-backup-content>
