<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash-window theme. The full UI is Compose; this theme only controls
         the launch window/splash screen background before Compose mounts. -->
    <style name="Theme.Nova" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/uc_bg</item>
        <item name="postSplashScreenTheme">@style/Theme.Nova.Material</item>
    </style>

    <style name="Theme.Nova.Material" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/uc_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
