<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- REQUEST_INSTALL_PACKAGES is declared in src/direct/AndroidManifest.xml
         only (ADR-0040): the `direct` distribution flavor carries the in-app
         updater + PackageInstaller pipeline, the `store` flavor does not. -->

    <application
        android:name=".NovaApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nova"
        android:usesCleartextTraffic="true"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Nova"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|smallestScreenSize|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Catches PackageInstaller session callbacks for the in-app updater. -->
        <receiver
            android:name=".data.update.InstallStatusReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="io.github.nofuturekid.nova.action.INSTALL_STATUS" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
